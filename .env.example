# ─── Synacal Cost Estimator – Azure configuration ─────────────────────────────
# Copy this file to .env and fill in ONE of the two endpoint options below.

# ── Option A: Azure AI Foundry project endpoint (recommended) ─────────────────
# Found on: AI Foundry Home page → "Project endpoint"
# If the URL ends with .services.ai.azure.com, append /api/projects/_project
# Example: https://rg-dev-ktech-resource.services.ai.azure.com/api/projects/_project
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/_project

# ── Option B: Azure OpenAI endpoint ──────────────────────────────────────────
# Found on: AI Foundry → Models → click your deployment → "Target URI" (base part)
# Use this if you have a classic Azure OpenAI resource
# AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com

# API key (works for both options above)
# AI Foundry Home → "API key"  OR  AI Foundry → Models → your deployment → "Key"
AZURE_API_KEY=your-api-key-here

# Name of the agent shown in AI Foundry → Build → Agents
# Or paste the full assistant ID (starts with asst_) to skip the name-lookup call
AZURE_AGENT_NAME=dev-ktech-demo

# Optional: Azure OpenAI API version (only used when AZURE_AI_ENDPOINT is *.openai.azure.com)
# AZURE_OPENAI_API_VERSION=2024-05-01-preview
