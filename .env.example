# ─── Synacal Cost Estimator – Azure configuration ─────────────────────────────
# Copy this file to .env and fill in your values.

# Endpoint (Responses) — paste from: AI Foundry → Agents → dev-ktech-demo
#   → Publish panel → "Endpoint (Responses)"
# Looks like: https://resource.services.ai.azure.com/api/projects/name/openai/v1/responses
# Also accepts shorter forms: just the base domain or the project endpoint.
AZURE_AI_ENDPOINT=https://rg-dev-ktech-resource.services.ai.azure.com/api/projects/_project/openai/v1/responses

# API key — AI Foundry Home page → "API key" field
AZURE_API_KEY=your-api-key-here

# Agent name — exactly as shown in AI Foundry → Build → Agents
AZURE_AGENT_NAME=dev-ktech-demo
