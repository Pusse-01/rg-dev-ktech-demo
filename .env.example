# ─── Synacal Cost Estimator – Azure configuration ─────────────────────────────
# Copy this file to .env and fill in your values.

# Azure AI Foundry project endpoint
# Found on: AI Foundry Home page → "Project endpoint"
# If the URL ends with .services.ai.azure.com, append /api/projects/_project
# Example: https://rg-dev-ktech-resource.services.ai.azure.com/api/projects/_project
AZURE_AI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/_project

# Project API key
# Found on: AI Foundry Home page → "API key"
AZURE_API_KEY=your-api-key-here

# Name of the agent in Azure AI Foundry (Build → Agents)
AZURE_AGENT_NAME=dev-ktech-demo
